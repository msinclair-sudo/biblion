{
  "_comment": "Per-engine API rate limits shared across ALL biblion producers via the cross-process rate limiter (biblion/clients/ratelimit.py). 'rps' = max requests/second enforced globally (all processes hitting this API on one Redis share it). 'daily' = max requests per UTC calendar day; 0 means unlimited. When an engine's daily cap is reached, producers stop that engine gracefully until UTC midnight. Drop a copy of this file in your working directory to override the shipped defaults.",
  "s2":       {"rps": 5, "daily": 0},
  "openalex": {"rps": 5, "daily": 9500},
  "ncbi":     {"rps": 8, "daily": 0},
  "crossref": {"rps": 5, "daily": 0}
}
