# node / npm — not used now, but in case we ever add a build step
node_modules/
package-lock.json

# python — conda env file is committed; the env itself is not
__pycache__/
*.pyc
.venv/
.env

# editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# transient
*.log
*.tmp
.cache/

# claude code workspace files (kept locally, not shared)
.claude/
CLAUDE.md

# UI plan — working note, not part of the tracked docs
doc/ui.md

# private planning / roadmap / research docs — kept local because they
# describe in-flight design + decision history rather than the shipped
# technical reality. Public technical docs (current behaviour + future
# direction) live under doc/ alongside these and ARE tracked. Future
# planning notes should follow the same convention: any *-plan.md or
# similarly scoped doc stays local.
doc/plan.md
doc/clustering-research.md
doc/*-plan.md

# diagnostic harnesses and acceptance scripts kept locally, not shared
scratch/

# user-generated project archives (File ▾ → Save in the app) — these
# are personal exports of session state, not source code.
saves/

# legacy real-data pipeline — the v3 toy is moving away from this
# framework; nothing in literture-network/ is committed even though the
# toy currently reads its dev_subset artifacts for the real data-source
# path. Code that depends on those artifacts treats them as
# locally-materialised inputs, not tracked fixtures.
literture-network/

# materialised ingest artifacts (db snapshot + SPECTER2 .npy + index)
# built by tools/ingest/ from a biblion db; large binaries, not source
data/

# vendored biblion repo (its own git repo + bundles a test DB). The toy
# reads a biblion db only to BUILD data/ via tools/ingest/; the repo itself
# is an external dependency, not this project's source.
biblion/

# personal working notes / brain-dump — not project source.
pending_changes.md
