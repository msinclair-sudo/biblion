docs/conflict_resolution_discussion.md

# network-toy viewer lives in-repo at network_toy/ (single repo as of the
# monorepo merge). Its nested network_toy/.gitignore covers node_modules/,
# data/, scratch/; real corpus data is covered by the data/** rules below + *.db.

# Generated network-toy snapshot/embedding artifacts (live next to the DBs
# under data/<project>/; the *_snapshot.db files are covered by *.db below)
data/**/paper_index.json
data/**/nodes.jsonl
data/**/manifest.json
data/**/embeddings.npy

# Stray temp artifact from an unexpanded shell var
$TMPDB

